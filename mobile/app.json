{
  "expo": {
    "name": "MAP",
    "slug": "map-mobile",
    "version": "0.1.0",
    "icon": "./assets/icon-map.png",
    "orientation": "portrait",
    "scheme": "memorytree",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "app.memorytree.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-map.png",
        "backgroundColor": "#07111f"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "app.memorytree.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ],
        "NSLocationWhenInUseUsageDescription": "Memory Tree can su dung vi tri de hien thi room va theo doi hanh trinh cua ban.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Memory Tree can vi tri nen de cap nhat room chung ngay ca khi app o background."
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Memory Tree can vi tri cua ban de hien thi room va chia se hanh trinh.",
          "locationAlwaysAndWhenInUsePermission": "Memory Tree can truy cap vi tri nen de dong bo hanh trinh cho room chung.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "31114ae0-c2ad-4c50-97bb-b941978aca4b"
      }
    }
  }
}
